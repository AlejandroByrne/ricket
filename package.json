{
  "name": "ricket",
  "version": "0.1.0",
  "description": "Vault-powered context engine for AI coding agents. Triage notes into your Obsidian vault, serve decisions and standards to Claude Code / GitHub Copilot via MCP.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ricket": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "obsidian",
    "mcp",
    "ai",
    "vault",
    "triage",
    "pkm",
    "claude",
    "copilot",
    "context"
  ],
  "author": "Alejandro Byrne",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlejandroByrne/ricket.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "sql.js": "^1.14.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
